{
  "compilerOptions": {
    "lib": [
      "es2023"
    ],
    "moduleDetection": "force",
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "types": [
      "node"
    ],
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "paths": {
      "agent":["../src/index.ts"]
    }
  },
  "include": [
    "src"
  ]
}